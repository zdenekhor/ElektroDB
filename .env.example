# ElektroDB - Environment Configuration

# Databáze
DB_PATH=./data/elektro-db.sqlite
DB_NAME=elektro-db

# Node.js
NODE_ENV=development
NODE_PORT=3000

# Volitelně: HTTP Basic Auth pro veřejný deploy
# Pokud nastavíte obě proměnné, aplikace bude chráněná heslem.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Soubory
DATA_DIR=./data
EXPORTS_DIR=./exports

# DBF Import
DBF_SOURCE_DIR=./PŘEHLED/csn_data

# Logging
LOG_LEVEL=info
